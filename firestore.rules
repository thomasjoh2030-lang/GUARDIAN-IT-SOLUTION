rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "thomasjoh2030@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      // Only admins can change roles. Users cannot escalate their own privilege level.
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Collection: Services
    match /services/{serviceId} {
      allow read: if true; // Anyone can browse offerings
      allow write: if isAdmin(); // Only admins can construct/edit/delete IT services
    }

    // Collection: Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid && 
         request.resource.data.userId == resource.data.userId &&
         request.resource.data.status == resource.data.status) // User can update order details (e.g. proof) but not change its verification status
      );
      allow delete: if isAdmin();
    }

    // Collection: Tickets
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Collection: Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn(); // Any authenticated action can create alerts
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Collection: Theme Settings
    match /theme/global {
      allow read: if true; // Anyone can read website branding colors
      allow write: if isAdmin(); // Only admin can overwrite portal styles
    }
  }
}
